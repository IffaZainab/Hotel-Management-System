# Dropdown menu function
def create_services_dropdown(button):
    # Common font style
    menu_font = ('Arial', 14, 'bold')

    # Main dropdown menu
    dropdown = tk.Menu(button, tearoff=0, bg='white', fg='black', font=menu_font, activebackground='#f0f0f0',
                       activeforeground='blue')

    # Submenu for "Meetings & Events"
    meetings_menu = tk.Menu(dropdown, tearoff=0, bg='white', fg='black', font=menu_font, activebackground='#f0f0f0',
                            activeforeground='blue')
    meetings_menu.add_command(label="Wedding", command=open_wedding_window)
    meetings_menu.add_command(label="Birthday", command=open_birthday_window)
    meetings_menu.add_command(label="Board Room", command=open_board_room_window)

    # Add submenu cascade and other options
    dropdown.add_cascade(label="Meetings & Events", menu=meetings_menu)
    dropdown.add_command(label="Restaurant", command=open_Restraunt)
    dropdown.add_command(label="Laundry", command=open_laundary)

    # Position dropdown under the button
    x = button.winfo_rootx()
    y = button.winfo_rooty() + button.winfo_height()
    dropdown.post(x, y)
    return dropdown
