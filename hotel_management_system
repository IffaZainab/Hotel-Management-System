splash.title("Platinum Court Hotel")
splash.attributes('-fullscreen', True)
splash.configure(bg=BG_COLOR)

# Splash logo
logo_path = r"C:\Users\User\OneDrive\Pictures\project\logo.jpg"
try:
    logo_image = Image.open(logo_path).resize((200, 200), Image.Resampling.LANCZOS)
    logo_photo = ImageTk.PhotoImage(logo_image)
    logo_label = tk.Label(splash, image=logo_photo, bg=BG_COLOR)
    logo_label.image = logo_photo
    logo_label.place(relx=0.5, rely=0.5, anchor='center')
except FileNotFoundError:
    print("Splash logo not found")
    logo_label = tk.Label(splash, text="Platinum Court Hotel",
                          font=('Arial', 32), bg=BG_COLOR, fg='white')
    logo_label.place(relx=0.5, rely=0.5, anchor='center')

# Start transition
splash.after(2000, _go_to_main_window)
splash.mainloop()












